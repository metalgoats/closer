{
  "name": "closer",
  "private": true,
  "version": "0.1.0",
  "description": "Post-call assistant for high-ticket closers: Fathom transcript in, debrief + text + email + CRM note out.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply closer --local",
    "db:migrate:remote": "wrangler d1 migrations apply closer --remote",
    "db:seed:local": "wrangler d1 execute closer --local --file=./seed/seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
